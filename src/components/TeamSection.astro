---
import * as IndustryData from "@/content/team-content.md";
import { Image } from "astro:assets";
import sectionIcon from "@/assets/team/teamicon.png";

// Access the frontmatter data
const { title, subtitle, description, categories } = IndustryData.frontmatter;
---

<section class="py-16 px-4 md:px-8 bg-white font-sans">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex flex-col lg:flex-row border-b border-white/20 my-5">
      <!-- Left: Icon + Title -->
      <div
        class="w-full lg:w-[15%] border-b lg:border-b-0 lg:border-r border-white/20 px-6 sm:px-8 py-5 md:py-8 lg:py-10"
      >
        <div class="flex items-center gap-3">
          <Image
            src={sectionIcon}
            alt="Latest icon"
            width={16}
            height={14}
            class="w-5 h-5 md:w-auto md:h-auto"
          />
          <h6
            class="font-dm-mono font-normal text-[12px] sm:text-[14px] leading-[150%] tracking-[-4%] text-primary"
          >
            {title}
          </h6>
        </div>
      </div>

      <!-- Middle: SubTitle -->
      <div
        class="w-full lg:w-[40%] border-b lg:border-b-0 lg:border-r border-white/20 px-6 sm:px-8 py-5 md:py-8 lg:py-10"
      >
        <p
          class="font-commissioner font-semibold text-[25px] sm:text-[22px] md:text-[24px] leading-[110%] tracking-[-4%] uppercase text-[#301C1B]"
        >
          {subtitle}
        </p>
      </div>

      <!-- Right: Description -->
      <div class="w-full lg:w-[46%] px-2 py-5 md:py-8 lg:py-10">
        <p
          class="text-[#301C1B] font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%]"
        >
          {description}
        </p>
      </div>
    </div>

    <!-- Team Grid -->
    <div
      class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 border-l border-t border-primary"
    >
      {
        categories?.map((member: any) => (
          <div class="group border-r border-b border-primary bg-[#FFFDFC]">
            {/* Image */}
            <div
              class="relative overflow-hidden  bg-[radial-gradient(circle,rgba(249,115,22,0.15)_1px,transparent_1px)]
         bg-size-[12px_12px]
         sm:bg-size-[14px_14px]
         lg:bg-size-[16px_16px]"
            >
              <Image
                src={member.image}
                alt={member.name}
                width={400}
                height={500}
                class="w-full h-55 object-cover object-top px-4 pt-2 transition-transform duration-500 group-hover:scale-105"
              />
            </div>

            {/* Content */}
            <div class="bg-white text-center px-6 py-5 border-t border-primary">
              <h3 class="font-dm-mono text-[18px] leading-[150%] font-medium tracking-[-4%] text-center text-[#301C1B]">
                {member.name}
              </h3>

              <p class="mt-2 font-dm-mono text-[14px] leading-[150%] font-normal tracking-[-4%] text-center text-[#301C1B]">
                {member.designation}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
