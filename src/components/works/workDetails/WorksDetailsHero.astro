---
const { title, description, image } = Astro.props;
---

<section class="border-b border-black/20">
  <div class="flex flex-col lg:flex-row">
    <!-- Left -->
    <div
      class="w-full lg:w-100 xl:w-105 shrink-0
             border-b lg:border-b-0 lg:border-r border-primary
             bg-white
             px-6 sm:px-8 lg:px-10
             py-10 lg:py-14
             flex flex-col justify-center"
    >
      <h2
        class="font-commissioner
               text-primary
               uppercase
               font-semibold
               text-[28px]
               leading-[110%]
               tracking-[-0.04em]"
      >
        {title}
      </h2>

      <p
        class="mt-10 lg:mt-20
               max-w-77.5
               font-dm-mono
               text-[#5B5151]
               text-[15px]
               leading-[180%]
               tracking-[-0.04em]"
      >
        {description}
      </p>
    </div>

    <!-- Right -->
    <div class="flex-1 max-h-80 lg:max-h-150">
      <img src={image} alt={title} class="w-full h-full object-cover" />
    </div>
  </div>
 
</section>
