---
const { projectInfo } = Astro.props;
---

<div class="flex flex-wrap lg:flex-nowrap items-start gap-x-10 gap-y-8 py-10 border-b border-primary px-10">
  {
    projectInfo.map((item: any) => (
      <div
        class:list={[
          item.label === "Deliverables" ? "flex-1 min-w-0" : "w-fit flex-none",
        ]}
      >
        <h4 class="font-dm-mono font-medium text-[16px] leading-[150%] tracking-[-0.04em] text-[#301C1B] whitespace-nowrap">
          {item.label}:
        </h4>

        <p class="mt-3 font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-0.04em] text-[#301C1B] ">
          {Array.isArray(item.value) ? item.value.join(" - ") : item.value}
        </p>
      </div>
    ))
  }
</div>
