---
const { projectScope } = Astro.props;
---

<section class="border-y border-black/20">
  <div class="flex flex-col lg:flex-row">
    <!-- Left -->
    <div
      class="w-full lg:w-105 shrink-0
             border-b lg:border-b-0 lg:border-r border-black/20
             px-8 lg:px-10 py-10"
    >
      <h2
        class="font-commissioner
               font-semibold
               uppercase
               text-[24px]
               leading-[110%]
               tracking-[-0.04em]
               text-[#301C1B]"
      >
        {projectScope.sectionTitle}
      </h2>
    </div>

    <!-- Right -->
    <div class="flex-1">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3">
        {
          projectScope.items.map((item: any, index: number) => (
            <div
              class:list={[
                "border-black/20 p-8 lg:p-10 min-h-47.5",
                "border-b",
                "md:border-r",
                (index + 1) % 3 === 0 && "xl:border-r-0",
              ]}
            >
              <h3
                class="font-commissioner
               font-semibold
               uppercase
               text-[24px]
               leading-[110%]
               tracking-[-0.04em] text-primary"
              >
                {item.number}
              </h3>

              <p
                class="mt-6
                       max-w-57.5
                       font-dm-mono
                       text-[14px]
                       leading-[150%]
                       tracking-[-4%]
                       text-[#301C1B]"
              >
                {item.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
