---
import NavHeader from "../NavHeader.astro";
import panzeLogo from "../../assets/panzeLogo.svg";
import navrighticon from "../../assets/navrighticon.svg";
---

<NavHeader
  logo={{
    src: panzeLogo,
    alt: "Panze",
    href: "/",
  }}
  navigation={[
    {
      label: "HOME",
      href: "/",
    },
    {
      label: "ABOUT",
      href: "/about",
    },
    {
      label: "SERVICES",
      href: "/services",
      links: [
        {
          label: "website",
          href: "/services/website",
        },
        {
          label: "Operations",
          href: "#",
        },
      ],
    },
    { label: "WORKS", href: "/works" },
    { label: "PRICING", href: "/pricing" },
    { label: "BLOG", href: "/blog" },
    { label: "CAREER", href: "/career" },
  ]}
  button={{ label: "Start trial", href: "#", icon: navrighticon }}
/>
