---
import LinkButton from "../ui/LinkButton.astro";
import Stepper from "./Stepper";
import sectionIcon from "@/assets/sectionIcon/networkIcon.svg";
const { ourProcess } = Astro.props;

const {
  title,
  subTitle,
  description,
  buttonText,
  buttonLink,
  ourPocessIcon,
  steps,
} = ourProcess.frontmatter;
// Sanitize the steps data
const data = {
  title,
  subTitle,
  description,
  buttonText,
  buttonLink,
  ourPocessIcon,
};
const sanitizedSteps = Array.isArray(steps)
  ? steps
      .map((step: any) => ({
        title: step.title?.trim() || "",
        description: step.description?.trim() || "",
        image: step.image?.trim() || "",
        imageAlt: step.imageAlt?.trim() || "",
        points: Array.isArray(step.points)
          ? step.points.map((point: string) => point.trim())
          : [],
      }))
      .filter(
        (step: any) => step.title && step.description && step.points.length > 0,
      )
  : [];
---

<section>
  <!-- large device -->
  <div class="hidden lg:block">
    <Stepper client:load data={data} steps={sanitizedSteps} />
  </div>

  <!-- smallDevices -->
  <div class="block lg:hidden mb-20">
    <div class="flex flex-col">
      <!-- Left Side - Fixed width with white background -->
      <div class="process-header px-8 w-full mt-20 mb-10 shrink-0 bg-white">
        <div class="process-badge flex items-center gap-2 mb-6">
          <img
            src={sectionIcon.src}
            alt="icon"
            width={16}
            height={14}
            class="w-5 h-5 md:w-auto md:h-auto"
          />
          <h6
            class="process-title font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%] text-primary"
          >
            {data.title}
          </h6>
        </div>
        <p
          class="process-title font-commissioner font-semiboldtext-[24px] leading-[110%] tracking-[-4%] uppercase pb-8"
        >
          {data.subTitle}
        </p>
        <p
          class="process-description font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%] pb-10"
        >
          {data.description}
        </p>
        <div class="process-button">
          <LinkButton href={buttonLink} text={buttonText} />
        </div>
      </div>
    </div>

    <!-- bottom component  -->
    <div>
      {
        steps.map((step: any, index: any) => (
          <div class="mx-8">
            <div
              class:list={[
                "step-card mx-auto py-12 px-15 border border-black/20 grid md:grid-cols-2 gap-2 items-center justify-center",
                index !== 0 && "border-t-0",
              ]}
            >
              {/* Image Section */}
              <div class="step-image mb-10 h-80 w-64.75 rounded-[180px] bg-gray-100 overflow-hidden relative">
                <img
                  src={step.image}
                  alt={step.imageAlt}
                  class="absolute inset-0 w-full h-full object-cover"
                />
              </div>
              {/* Content Section */}

              <div class="step-content">
                <h3 class="font-commissioner font-semibold text-[22px] uppercase mb-4">
                  {step.title}{" "}
                </h3>
                <p class="font-dm-mono font-medium text-[16px] leading-[150%] tracking-[-4%] mb-9">
                  {step.description}
                </p>
                <ul>
                  {step.points.map((item: any) => (
                    <li class="flex items-center gap-3">
                      <span class="text-[#301C1B] mt-1">-</span>
                      <span class="font-dm-mono font-normal text-[14px] text-[#301C1B] leading-[150%] tracking-[-4%]">
                        {item}
                      </span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  window.addEventListener("load", () => {
    if (window.innerWidth >= 1024) return;

    // Header Animation
    const header = document.querySelector(".process-header");

    if (header) {
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: header,
          start: "top 85%",
          toggleActions: "play none none reverse",
        },
      });

      tl.from(".process-badge", {
        opacity: 0,
        x: -40,
        duration: 0.6,
        ease: "power3.out",
      })
        .from(
          ".process-title",
          {
            opacity: 0,
            y: 50,
            duration: 0.8,
            ease: "power4.out",
          },
          "-=0.3",
        )
        .from(
          ".process-description",
          {
            opacity: 0,
            y: 30,
            duration: 0.7,
            ease: "power2.out",
          },
          "-=0.4",
        )
        .from(
          ".process-button",
          {
            opacity: 0,
            scale: 0.9,
            duration: 0.5,
            ease: "back.out(1.7)",
          },
          "-=0.3",
        );
    }

    // Cards Animation
    const cards = document.querySelectorAll(".step-card");

    cards.forEach((card) => {
      const image = card.querySelector(".step-image");
      const content = card.querySelector(".step-content");

      if (!image || !content) return;

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: card,
          start: "top 80%",
          toggleActions: "play none none reverse",
        },
      });

      tl.from(card, {
        opacity: 0,
        y: 100,
        duration: 0.8,
        ease: "power3.out",
      })
        .from(
          image,
          {
            scale: 0.85,
            opacity: 0,
            rotate: -4,
            duration: 0.8,
            ease: "power4.out",
          },
          "-=0.5",
        )
        .from(
          Array.from(content.children),
          {
            opacity: 0,
            y: 25,
            stagger: 0.15,
            duration: 0.5,
            ease: "power2.out",
          },
          "-=0.4",
        );
    });
  });
</script>
