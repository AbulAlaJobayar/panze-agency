---
import Stepper from "./Stepper";
import { NavigationMenuLink } from "../ui/navigation-menu";
import { Image } from "astro:assets";
const { ourProcess } = Astro.props;

const {
  title,
  subTitle,
  description,
  buttonText,
  buttonLink,
  ourPocessIcon,
  steps,
} = ourProcess.frontmatter;
// Sanitize the steps data
const sanitizedSteps = Array.isArray(steps)
  ? steps
      .map((step: any) => ({
        title: step.title?.trim() || "",
        description: step.description?.trim() || "",
        image: step.image?.trim() || "",
        imageAlt: step.imageAlt?.trim() || "",
        points: Array.isArray(step.points)
          ? step.points.map((point: string) => point.trim())
          : [],
      }))
      .filter(
        (step: any) => step.title && step.description && step.points.length > 0,
      )
  : [];
---

<section class="border-b overflow-hidden">
  <div class="flex flex-col lg:flex-row items-stretch">
    <!-- Left Side - Fixed width with white background -->
    <div
      class="w-full lg:w-100 shrink-0 border-b lg:border-b-0 lg:border-r px-6 sm:px-8 md:px-10 py-10 md:py-12 lg:py-16 bg-white"
    >
      <div class="flex items-center gap-3 mb-6 md:mb-8">
        <img
          src={ourPocessIcon}
          alt="number section"
          width={16}
          height={14}
          class="w-5 h-5 md:w-auto md:h-auto"
        />
        <h6
          class="font-dm-mono font-normal text-[12px] sm:text-[14px] leading-[150%] tracking-[-4%] text-primary"
        >
          {title}
        </h6>
      </div>
      <p
        class="font-commissioner font-semibold text-[20px] sm:text-[22px] md:text-[24px] leading-[110%] tracking-[-4%] uppercase pb-6 md:pb-15 lg:pb-20"
      >
        {subTitle}
      </p>
      <p
        class="font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%] xl:pb-20"
      >
        {description}
      </p>
      <NavigationMenuLink
        href={buttonLink}
        class="w-36.25 h-11.25 py-3 px-2.5 bg-primary mt-10 hover:bg-primary cursor-pointer flex items-center justify-center gap-2 rounded-none"
      >
        <span
          class="font-commissioner font-normal text-[14px] leading-[150%] tracking-[-4%] text-white"
        >
          {buttonText}
        </span>
        <svg
          class="text-white"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
        >
          <path
            d="M7 17L17 7M17 7H9M17 7V15"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </NavigationMenuLink>
    </div>

    <!-- Right Side - Background image ONLY on right side -->
    <div class="py-10 md:py-12 lg:py-16 bg-white">
      <Stepper client:load steps={sanitizedSteps} />
    </div>
  </div>
</section>
