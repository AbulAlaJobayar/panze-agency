---
import * as data from "@/content/about/clients-content.md";
import Icon from "../ui/icon/icon.astro";

const { title, description, clients, industries } = data.frontmatter;

const { firstRow, secondRow } = industries;
---

<section class="bg-[#2E1C1B] mt-28 px-8">
  <div class="mx-auto max-w-300 py-26">
    <!-- Header -->
    <div
      class="grid gap-8  border-[#4A3432] pb-16 lg:grid-cols-[220px_1fr]"
    >
      <div>
        <h2
          class="font-semibold uppercase text-white font-commissioner leading-[110%] tracking-[-4%] text-[24px]"
        >
          {title}
        </h2>
      </div>

      <div>
        <p
          class="max-w-160 font-normal uppercase text-white font-dm-mono leading-[150%] tracking-[-4%] text-[14px]"
        >
          {description}
        </p>
      </div>
    </div>

    <!-- Logo Grid -->
    <div
      class=" grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 border-l border-t
  border-[#4A3432]"
    >
      {
        clients.map((client: any) => (
          <div
            class="flex py-19.25 items-center justify-center
                   border-r border-b border-[#4A3432]
                   px-9.25 transition-colors duration-300
                   hover:bg-[#35211F]"
          >
            <img
              src={client.logo}
              alt={client.name}
              class="max-h-12 w-auto object-contain opacity-95"
            />
          </div>
        ))
      }
    </div>
    <!-- Industry Tags -->
    <div class="flex flex-col items-center">
      <!-- First Row -->

      <div class="flex flex-wrap border-l border-t border-[#4A3432]">
        {
          firstRow.map((industry: any) => (
            <div
              class="flex items-center gap-3
               border-r border-b border-[#4A3432]
               px-5.5 py-6"
            >
              <Icon
                name="check"
                class="size-3 shrink-0 border border-primary text-primary"
              />

              <span class="font-dm-mono text-[14px] text-primary">
                {industry}
              </span>
            </div>
          ))
        }
      </div>
      <!-- Second Row (Centered) -->
      <div class="flex flex-wrap border-l border-t border-[#4A3432]">
        {
          secondRow.map((industry: any) => (
            <div
              class="flex items-center gap-3
               border-r border-b border-[#4A3432]
               px-5.5 py-6"
            >
              <Icon
                name="check"
                class="size-3 shrink-0 border border-primary text-primary"
              />

              <span class="font-dm-mono text-[14px] text-primary">
                {industry}
              </span>
            </div>
          ))
        }
      </div>
    
    </div>
  </div>
</section>
