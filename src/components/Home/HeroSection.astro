---
import { NavigationMenuLink } from "../ui/navigation-menu";

import {
  Carousel,
  CarouselContent,
  CarouselItem,
} from "@/components/ui/carousel";
const { hero } = Astro.props;
const { image, usFlag, cta, location, description, subTitle, title } =
  hero.frontmatter;
---

<!-- hero section -->
<div>
  <!-- dextop screen -->
  <div class="hidden md:block">
    <div class="flex">
      <!-- left container -->
      <div class="w-100 border-r ml-10 pb-20">
        <div class="w-83.75">
          <h3
            class="font-commissioner font-semibold text-[28px] uppercase leading-[110%] tracking-[-4%] text-primary py-14"
          >
            {subTitle}
          </h3>
          <p
            class="font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%]"
          >
            {description}
          </p>
          <NavigationMenuLink
            href={"/works"}
            class={"w-36.25 h-11.25 py-3 px-2.5 bg-primary mt-10 hover:bg-primary cursor-pointer flex items-center justify-center gap-2 rounded-none"}
          >
            <span
              class="font-commissioner font-normal text-[14px] leading-[150%] tracking-[-4%] text-white"
            >
              {cta}</span
            >
            <svg
              class="text-white"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
            >
              <path
                d="M7 17L17 7M17 7H9M17 7V15"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </NavigationMenuLink>
        </div>
      </div>
      <!-- right container -->
      <div class="max-w-200 mt-10">
        <!-- top -->
        <div class="pl-4">
          <div class="flex items-center gap-2">
            <img src={usFlag} alt="icon" width={24} height={16} />
            <!-- <img src={hero.locationIcon} alt="icon" class="h-4 w-6" /> -->
            <p
              class="font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%] text-primary"
            >
              {location}
            </p>
          </div>

          <h1
            class="font-commissioner font-semibold text-[50px] lg:text-[110px] uppercase leading-[150%] xl:-mt-6 tracking-[-4%] text-[#301C1B]"
          >
            {title}
          </h1>
        </div>
        <!-- carosel -->
        <Carousel
          class="mt-30"
          opts={{
            loop: true,
            align: "start",
          }}
        >
          <CarouselContent>
            {
              image.map((img: any) => (
                <CarouselItem class="md:basis-1/2 lg:basis-1/3">
                  <img src={img} alt="banner" />
                </CarouselItem>
              ))
            }
          </CarouselContent>
        </Carousel>
      </div>
    </div>
  </div>
    <!-- small screen -->
  <div>
    <div class="block md:hidden mx-auto px-4">
      <div class="mt-10">
        <!-- top -->
        <div class="pl-2">
          <div class="flex items-center gap-2">
            <img src={usFlag} alt="icon" width={12} height={8} />
            <p
              class="font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%] text-primary"
            >
              {location}
            </p>
          </div>

          <h1
            class="font-commissioner font-semibold text-5xl uppercase leading-[120%] tracking-[-4%] text-[#301C1B]"
          >
            {title}
          </h1>
        </div>
        <div class="pl-2">
          <div class="max-w-80">
            <h3
              class="font-commissioner font-semibold text-[18px] uppercase leading-[110%] tracking-[-4%] text-primary py-3"
            >
              {subTitle}
            </h3>
            <p
              class="font-dm-mono font-normal text-[12px] leading-[140%] tracking-[-4%]"
            >
              {description}
            </p>
          </div>
        </div>
        <!-- carosel -->
        <Carousel class="mt-0">
          <CarouselContent>
            {
              image.map((img: any) => (
                <CarouselItem class="md:basis-1/2 lg:basis-1/3">
                  <img src={img} alt="banner" />
                </CarouselItem>
              ))
            }
          </CarouselContent>
        </Carousel>
        <NavigationMenuLink
          href={"/works"}
          class={"mb-5 w-28 h-7 py-1 px-1 bg-primary mt-3 hover:bg-primary cursor-pointer flex items-center justify-center mx-auto gap-2 rounded"}
        >
          <span
            class="font-commissioner font-normal text-[12px] leading-[150%] tracking-[-4%] text-white"
          >
            {cta}</span
          >
          <svg
            class="text-white"
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
          >
            <path
              d="M7 17L17 7M17 7H9M17 7V15"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </NavigationMenuLink>
      </div>
    </div>
  </div>
</div>
