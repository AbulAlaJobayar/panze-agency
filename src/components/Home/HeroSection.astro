---
import { NavigationMenuLink } from "../ui/navigation-menu";
import ctaIcon from "@/assets/heroimage/ctaActionIcon.svg";
import flag from "@/assets/heroimage/usflag.svg";
import bg from "@/assets/heroimage/bg.svg";
import firstimage from "@/assets/heroimage/herofirstimg.svg";
import secondimage from "@/assets/heroimage/heroseimg.svg";
import thirdimage from "@/assets/heroimage/herothirdimage.png";
import { Image } from "astro:assets";
import Autoplay from "embla-carousel-autoplay";
import {
  Carousel,
  CarouselContent,
  CarouselItem,
  CarouselNext,
  CarouselPrevious,
} from "@/components/ui/carousel";
const { hero } = Astro.props;

const autoplayPlugin = Autoplay({
  delay: 3000,
  stopOnInteraction: true,
});
---

<!-- hero section -->
<div>
  <!-- dextop screen -->
  <div class="hidden md:block pb-10">
    <div class="flex">
      <!-- left container -->
      <div class="w-100 border-r ml-10">
        <div class="w-83.75">
          <h3
            class="font-commissioner font-semibold text-[28px] uppercase leading-[110%] tracking-[-4%] text-primary py-14"
          >
            {hero.frontmatter.subTitle}
          </h3>
          <p
            class="font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%]"
          >
            {hero.frontmatter.description}
          </p>
          <NavigationMenuLink
            href={"/works"}
            class={"w-36.25 h-11.25 py-3 px-2.5 bg-primary mt-10 hover:bg-primary cursor-pointer flex items-center justify-center gap-2 rounded-none"}
          >
            <span
              class="font-commissioner font-normal text-[14px] leading-[150%] tracking-[-4%] text-white"
            >
              {hero.frontmatter.cta}</span
            >
            <img src={ctaIcon.src} alt="icon" class="h-2 w-2" />
          </NavigationMenuLink>
        </div>
      </div>
      <!-- right container -->
      <div class="max-w-200 mt-10">
        <!-- top -->
        <div class="pl-4">
          <div class="flex items-center gap-2">
            <Image src={flag} alt="icon" width={24} height={16} />
            <!-- <img src={hero.locationIcon} alt="icon" class="h-4 w-6" /> -->
            <p
              class="font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%] text-primary"
            >
              {hero.frontmatter.location}
            </p>
          </div>

          <h1
            class="font-commissioner font-semibold text-[110px] uppercase leading-[150%] -mt-6 tracking-[-4%] text-[#301C1B]"
          >
            {hero.frontmatter.title}
          </h1>
        </div>
        <!-- carosel -->
        <Carousel
          class="mt-20"
          opts={{
            loop: true,
            align: "start",
            // slides:[autoplayPlugin]
            // plugins: [autoplayPlugin], // Plugins inside opts
          }}
        >
          <CarouselContent>
            <CarouselItem class="md:basis-1/2 lg:basis-1/3">
              <Image src={firstimage} alt="banner" />
            </CarouselItem>
            <CarouselItem class="md:basis-1/2 lg:basis-1/3">
              <Image src={secondimage} alt="banner" />
            </CarouselItem>
            <CarouselItem class="md:basis-1/2 lg:basis-1/3">
              <Image src={thirdimage} alt="banner" />
            </CarouselItem>
          </CarouselContent>
        </Carousel>
      </div>
    </div>
  </div>
  <!-- small screen -->
  <div class="block md:hidden">
    <div class="mt-10">
      <!-- top -->
      <div class="pl-2">
        <div class="flex items-center gap-2">
          <Image src={flag} alt="icon" width={12} height={8} />
          <p
            class="font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%] text-primary"
          >
            {hero.frontmatter.location}
          </p>
        </div>

        <h1
          class="font-commissioner font-semibold text-5xl uppercase leading-[120%] tracking-[-4%] text-[#301C1B]"
        >
          {hero.frontmatter.title}
        </h1>
      </div>
      <div class="pl-2">
        <div class="max-w-80">
          <h3
            class="font-commissioner font-semibold text-[18px] uppercase leading-[110%] tracking-[-4%] text-primary py-3"
          >
            {hero.frontmatter.subTitle}
          </h3>
          <p
            class="font-dm-mono font-normal text-[12px] leading-[140%] tracking-[-4%]"
          >
            {hero.frontmatter.description}
          </p>
        </div>
      </div>
      <!-- carosel -->
      <Carousel class="mt-20">
        <CarouselContent>
          <CarouselItem class="md:basis-1/2 lg:basis-1/3">
            <Image src={firstimage} alt="banner" />
          </CarouselItem>
          <CarouselItem class="md:basis-1/2 lg:basis-1/3">
            <Image src={secondimage} alt="banner" />
          </CarouselItem>
          <CarouselItem class="md:basis-1/2 lg:basis-1/3">
            <Image src={thirdimage} alt="banner" />
          </CarouselItem>
        </CarouselContent>
      </Carousel>
      <NavigationMenuLink
        href={"/works"}
        class={"w-28 h-7 py-1 px-1 bg-primary mt-3 hover:bg-primary cursor-pointer flex items-center justify-center mx-auto gap-2 rounded"}
      >
        <span
          class="font-commissioner font-normal text-[12px] leading-[150%] tracking-[-4%] text-white"
        >
          {hero.frontmatter.cta}</span
        >
        <img src={ctaIcon.src} alt="icon" class="h-2 w-2" />
      </NavigationMenuLink>
    </div>
  </div>
</div>
