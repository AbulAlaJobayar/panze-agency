---
import { Image } from "astro:assets";
import * as aboutData from "@/content/home/aboutus-content.md";
import { NavigationMenuLink } from "../ui/navigation-menu";
import ctaIcon from "@/assets/home/heroimage/ctaActionIcon.svg";

// Access frontmatter data
const {
  title,
  subTitle,
  description,
  buttonText,
  buttonLink,
  abouticon,
  background,
  image1,
  image2,
  image3,
  image4,
  imageAlt1,
  imageAlt2,
  imageAlt3,
  imageAlt4,
} = aboutData.frontmatter;

// Create images array for rendering
const images = [
  { path: image1, alt: imageAlt1 || "About us image 1" },
  { path: image2, alt: imageAlt2 || "About us image 2" },
  { path: image3, alt: imageAlt3 || "About us image 3" },
  { path: image4, alt: imageAlt4 || "About us image 4" },
];
---

<section class="border-b overflow-hidden">
  <div class="flex flex-col lg:flex-row items-stretch">
    <!-- Left Side - Fixed width with white background -->
    <div
      class="w-full lg:w-100 shrink-0 border-b lg:border-b-0 lg:border-r px-6 sm:px-8 md:px-10 py-10 md:py-12 lg:py-16 bg-white"
    >
      <div class="flex items-center gap-3 mb-6 md:mb-8">
        <Image
          src={abouticon}
          alt="number section"
          width={16}
          height={14}
          class="w-5 h-5 md:w-auto md:h-auto"
        />
        <h6
          class="font-dm-mono font-normal text-[12px] sm:text-[14px] leading-[150%] tracking-[-4%] text-primary"
        >
          {title}
        </h6>
      </div>
      <p
        class="font-commissioner font-semibold text-[20px] sm:text-[22px] md:text-[24px] leading-[110%] tracking-[-4%] uppercase pb-6 md:pb-8 lg:pb-10"
      >
        {subTitle}
      </p>
      <p
        class="font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%]"
      >
        {description}
      </p>
      <NavigationMenuLink
        href={buttonLink}
        class="w-36.25 h-11.25 py-3 px-2.5 bg-primary mt-10 hover:bg-primary cursor-pointer flex items-center justify-center gap-2 rounded-none"
      >
        <span
          class="font-commissioner font-normal text-[14px] leading-[150%] tracking-[-4%] text-white"
        >
          {buttonText}
        </span>
        <svg
          class="text-white"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
        >
          <path
            d="M7 17L17 7M17 7H9M17 7V15"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </NavigationMenuLink>
    </div>

    <!-- Right Side - Background image ONLY on right side -->
    <div
      style={{ backgroundImage: `url(${background})` }}
      class="flex-1 bg-cover bg-center bg-no-repeat p-4 md:p-6 lg:p-8 min-h-100 lg:min-h-[unset]"
    >
      <div class="grid grid-cols-2 gap-4 md:gap-6 lg:gap-8 h-full">
        {
          images.map(({ path, alt }) => (
            <div class="flex items-center justify-center">
              <img src={path} alt={alt} class="w-auto h-auto max-w-full" />
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
