---
import * as blogContent from "@/content/home/blog-content.md";
import { NavigationMenuLink } from "../ui/navigation-menu";
import ctaIcon from "/public/ourProcess/ctaActionIcon.svg";
import { Image } from "astro:assets";
import sectionIcon from "@/assets/home/blog/blogSectionIcon.png";
import LinkButton from "../ui/LinkButton.astro";
const { title, subtitle, description, buttonText, buttonLink } =
  blogContent.frontmatter;

const blogs = Object.values(
  import.meta.glob("../../content/blogs/blog/*.{md,mdx}", { eager: true }),
);
---

<div
  id="blog-section"
  class="mt-22.75 flex flex-col lg:flex-row items-stretch border-y"
>
  <!-- Left Side - Fixed width with white background -->
  <div
    class="w-full lg:w-100 shrink-0 border-b lg:border-b-0 lg:border-r bg-white"
  >
    <div class="mx-8 mt-13 lg:mt-26">
      <div class="home-blog-section-badge flex items-center gap-2 mb-6 lg:mb-9">
        <Image
          src={sectionIcon}
          alt="number section"
          width={16}
          height={14}
          class="w-4 h-4 md:w-auto md:h-auto"
        />
        <h6
          class="font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%] text-primary"
        >
          {title}
        </h6>
      </div>
      <p
        class="home-blog-section-subtitle font-commissioner font-semibold text-[24px] leading-[110%] tracking-[-4%] uppercase mb-8 lg:mb-49"
      >
        {subtitle}
      </p>
      <p
        class="home-blog-section-description mb-10 lg:mb-16 font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%]"
      >
        {description}
      </p>
      <LinkButton
        href={buttonLink}
        text={buttonText}
        class="home-blog-section-button mb-10"
      />
    </div>
  </div>
  <div class="grid sm:grid-cols-2 my-10 lg:my-20 gap-4 ml-8 lg:ml-4.25 mr-8">
    {
      blogs.slice(0, 4).map((blog: any) => (
        <a
          href={`/blog/${blog.frontmatter.slug}`}
          class="group mb-6 home-blog-section-card"
        >
          <div class="overflow-hidden">
            <img
              src={blog.frontmatter.image}
              alt={blog.frontmatter.thumbnailTitle}
              class="aspect-4/3 w-full object-cover transition duration-500 group-hover:scale-105"
            />
          </div>

          <h3 class="mt-2 font-dm-mono font-medium  text-[16px] leading-[150%] tracking-[-4%] text-[#301C1B]  group-hover:text-primary transition">
            {blog.frontmatter.title}
          </h3>
        </a>
      ))
    }
  </div>
</div>
<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener("astro:page-load", () => {
    const section = document.querySelector("#blog-section");

    if (!section) return;

    // Header Animation
    const headerTl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top 75%",
        toggleActions: "play none none reverse",
      },
    });

    headerTl
      .from(".home-blog-section-badge", {
        x: -60,
        opacity: 0,
        duration: 0.7,
        ease: "power3.out",
      })
      .from(
        ".home-blog-section-subtitle",
        {
          x: -50,
          opacity: 0,
          duration: 0.9,
          ease: "power4.out",
        },
        "-=0.4",
      )
      .from(
        ".home-blog-section-description",
        {
          x: -30,
          opacity: 0,
          duration: 0.7,
          ease: "power2.out",
        },
        "-=0.5",
      )
      .from(
        ".home-blog-section-button",
        {
          x: -20,
          opacity: 0,
          duration: 0.9,
          ease: "power2.out",
        },
        "-=0.6",
      );

    // Cards Animation
    gsap.from(".home-blog-section-card", {
      scrollTrigger: {
        trigger: ".home-blog-section-card",
        start: "top 85%",
        toggleActions: "play none none reverse",
      },
      opacity: 0,
      y: 80,
      scale: 0.95,
      duration: 0.8,
      ease: "power4.out",
      stagger: {
        each: 0.12,
        from: "start",
      },
    });
  });
</script>
