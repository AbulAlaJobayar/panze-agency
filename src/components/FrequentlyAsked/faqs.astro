---
import { cn } from "@/lib/utils";
import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from "../ui/accordion";

const { class: className, faqs } = Astro.props;
---

<div class={cn("", className)}>
  <div class="">
    <Accordion collapsible>
      {
        faqs.map((item: any, index: number) => (
          <AccordionItem
            value={item.id}
            class="accordion-item group lg:w-200 px-10 py-2.5 border-b border-[#301C1B]/10 transition-all duration-300 hover:bg-[#F8F5F4]"
          >
            <AccordionTrigger
              class={
                "accordion-trigger font-dm-mono font-medium text-[16px] leading-[150%] tracking-[-4%] text-[#301C1B] transition-all duration-300 hover:text-primary"
              }
            >
              {index + 1}. {item.question}
            </AccordionTrigger>
            <AccordionContent
              class={
                "accordion-content font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%] text-[#301C1B] data-[state=open]:animate-accordion-down data-[state=closed]:animate-accordion-up"
              }
            >
              {item.answer}
            </AccordionContent>
          </AccordionItem>
        ))
      }
    </Accordion>
  </div>
</div>
<style>
  /* Accordion Content */
  [data-state="open"] .accordion-content {
    animation: slideDown 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }

  [data-state="closed"] .accordion-content {
    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      max-height: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      max-height: 500px;
      transform: translateY(0);
    }
  }

  @keyframes slideUp {
    from {
      opacity: 1;
      max-height: 500px;
      transform: translateY(0);
    }
    to {
      opacity: 0;
      max-height: 0;
      transform: translateY(-8px);
    }
  }

  /* Trigger Hover Effect */
  .accordion-trigger {
    transition: all 0.3s ease;
  }

  .accordion-trigger:hover {
    padding-left: 8px;
  }

  /* Number Animation */
  .accordion-item {
    transition: all 0.3s ease;
    border-bottom: 1px solid rgba(48, 28, 27, 0.08);
  }

  .accordion-item[data-state="open"] {
    background: linear-gradient(90deg, rgba(235, 106, 66, 0.03), transparent);
  }

  /* Plus / Minus Rotation */
  .accordion-trigger svg {
    transition: transform 0.35s ease;
  }

  .accordion-item[data-state="open"] .accordion-trigger svg {
    transform: rotate(180deg);
  }
</style>
