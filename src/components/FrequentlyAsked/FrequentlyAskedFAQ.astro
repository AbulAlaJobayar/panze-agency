---
import { Image } from "astro:assets";
import { NavigationMenuLink } from "../ui/navigation-menu";
import Faqs from "./faqs.astro";
const whatsappUrl = import.meta.env.WHATSAPP_URL;
const { askedQuestion } = Astro.props;

const { sectionIcon, title, subtitle, description, buttonText, faqs } =
  askedQuestion.frontmatter;
---

<section class="overflow-hidden mt-20">
  <div class="flex flex-col lg:flex-row items-stretch border-y">
    <!-- Left Side - Fixed width with white background -->
    <div
      class="w-full lg:w-100 shrink-0 border-b lg:border-b-0 lg:border-r px-6 sm:px-8 md:px-10 py-10 md:py-12 lg:py-14 bg-white"
    >
      <div class="flex items-center gap-3 mb-6 md:mb-8">
        <Image
          src={sectionIcon}
          alt="number section"
          width={16}
          height={14}
          class="w-5 h-5 md:w-auto md:h-auto"
        />
        <h6
          class="font-dm-mono font-normal text-[12px] sm:text-[14px] leading-[150%] tracking-[-4%] text-primary"
        >
          {title}
        </h6>
      </div>
      <p
        class="font-commissioner font-semibold text-[20px] sm:text-[22px] md:text-[24px] leading-[110%] tracking-[-4%] uppercase pb-6 md:pb-15 lg:pb-20"
      >
        {subtitle}
      </p>
      <p
        class="font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%] xl:pb-20"
      >
        {description}
      </p>
      <NavigationMenuLink
        href={whatsappUrl}
        class="w-36.25 h-11.25 py-3 px-2.5 bg-primary mt-10 hover:bg-primary cursor-pointer flex items-center justify-center gap-2 rounded-none"
      >
        <span
          class="font-commissioner font-normal text-[14px] leading-[150%] tracking-[-4%] text-white"
        >
          {buttonText}
        </span>
        <svg
          class="text-white size-4"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
        >
          <path
            d="M7 17L17 7M17 7H9M17 7V15"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </NavigationMenuLink>
    </div>

    <!-- Right Side - Background image ONLY on right side -->
    <div class="py-5 md:py-7 lg:py-10p bg-white">
      <Faqs faqs={faqs} />
    </div>
  </div>
</section>
