---
import { Image } from "astro:assets";

import * as contactData from "@/content/contact-page-content.md";
import pattern from "@/assets/contact/bg.png";
import meet from "@/assets/contact/meet2.png";

import ctaIcon from "/public/ourProcess/ctaActionIcon.svg";
import whatappIcon from "@/assets/contact/whatsapp.png";
import { NavigationMenuLink } from "../ui/navigation-menu";
import ContactForm from "./ContactForm";

const contactUrl = import.meta.env.CONTACT_URL;
const whatsappUrl = import.meta.env.WHATSAPP_URL;
const { title, description, name, designation, ceoImage, meetDescription } =
  contactData.frontmatter;
---

<section>
  <div>
    <div class="flex flex-col lg:flex-row items-stretch px-10 border-b border-black/20 ">
      <!-- Left Side - Fixed width with white background -->
      <div
        class="w-full lg:w-106 shrink-0 border-b lg:border-b-0 lg:border-r px-6 sm:px-8 md:px-10 py-10 md:py-12 lg:py-12 border-black20"
      >
        <div class="">
          <h1
            class="font-commissioner font-semibold leading-[110%] tracking-[-4%] uppercase text-[28px] text-primary pb-10"
          >
            {title}
          </h1>
          <p
            class=" mb-5 font-dm-mono font-normal text-[14px] leading-[110%] tracking-[-4%]"
          >
            {description}
          </p>
          
          <div class="border border-primary">
            {/* Image */}
            <div
              class="relative overflow-hidden bg-[radial-gradient(circle,rgba(249,115,22,0.15)_1px,transparent_1px)]
         bg-size-[12px_12px]
         sm:bg-size-[14px_14px]
         lg:bg-size-[16px_16px]"
              style={`background-image: url(${pattern.src}); background-size: cover;`}
            >
              <Image
                src={ceoImage}
                alt={name}
                width={400}
                height={500}
                class="w-full max-h-80 object-cover object-top px-2 pt-2 transition-transform duration-500 hover:scale-105"
              />
            </div>

            {/* Content */}
            <div class="text-center px-6 py-5 border-t border-primary">
              <h3
                class="text-[#301C1B] font-dm-mono text-[18px] leading-[150%] font-medium tracking-[-4%] text-center"
              >
                {name}
              </h3>

              <p
                class="text-[#301C1B] mt-2 font-dm-mono text-[14px] leading-[150%] font-normal tracking-[-4%] text-center"
              >
                {designation}
              </p>
            </div>
          </div>
          <!-- left bottom side -->
          <div class="bg-[#301C1B] mt-10">
            <img src={meet.src} alt="Google Meet" class="px-5 py-5" />
            <h1 class="text-white w-70 px-5">{meetDescription}</h1>
            <div class="px-5 flex items-center gap-2">
              <NavigationMenuLink
                href={contactUrl}
                class="w-36.25 h-11.25 py-3 px-2.5 bg-primary mt-14 hover:bg-primary cursor-pointer flex items-center justify-center gap-2 rounded-none"
              >
                <span
                  class="font-commissioner font-normal text-[14px] leading-[150%] tracking-[-4%] text-white"
                >
                  Shedule call
                </span>
                <img src={ctaIcon.src} alt="icon" class="h-2 w-2" />
              </NavigationMenuLink>
              <NavigationMenuLink href={whatsappUrl} class="mt-14">
                <img src={whatappIcon.src} alt="icon" width={45} height={45} />
              </NavigationMenuLink>
            </div>
          </div>
        </div>
      </div>
      <!-- Right Side - Background image ONLY on right side -->
      <div class="py-5 md:py-7 lg:py-10p">
        <ContactForm client:load />
      </div>
    </div>
  </div>
</section>
