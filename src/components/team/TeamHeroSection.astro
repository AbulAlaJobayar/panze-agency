---
import * as data from "@/content/team/team-hero-content.md";
import NavigationMenuLink from "../ui/navigation-menu/navigation-menu-link.astro";
import { Image } from "astro:assets";
import pattern from "@/assets/contact/bg.png";
const {
  title,
  description,
  name,
  designation,
  ceoImage,
  cta,
  ctaLink,
  ctaIcon,
} = data.frontmatter;
---

<section class="border-b overflow-hidden mb-5 lg:mb-20">
  <div class="flex flex-col lg:flex-row items-stretch">
    <!-- Left Side - Fixed width with white background -->
    <div
      class="w-full lg:w-100 shrink-0 border-b lg:border-b-0 lg:border-r px-6 sm:px-8 md:px-8 py-6 md:py-8 lg:py-10 bg-white"
    >
      <h3
        class="font-commissioner font-semibold text-[28px] uppercase leading-[110%] tracking-[-4%] text-primary py-10"
      >
        {title}
      </h3>
      <p
        class="font-dm-mono mt-5 font-normal text-[14px] leading-[150%] tracking-[-4%]"
      >
        {description}
      </p>
      <!-- button -->
      <div class="flex gap-6">
        <NavigationMenuLink
          href={ctaLink}
          class="w-36.25 h-11.25 py-3 px-2.5 bg-primary my-10 mt-5 lg:mt-26 hover:bg-primary cursor-pointer flex items-center justify-center gap-2 rounded-none"
        >
          <span
            class="font-commissioner font-normal text-[14px] leading-[150%] tracking-[-4%] text-white"
          >
            {cta}
          </span>
          <img src={ctaIcon} alt="icon" />
        </NavigationMenuLink>
      </div>
    </div>

    <!-- Right Side -->
    <div class="flex-1 bg-[#1E1212] flex items-center justify-center">
      <div class="border border-white/20">
        <!-- Image -->
        <div
          class="relative overflow-hidden"
          style={`background-image: url(${pattern.src}); background-size: cover;`}
        >
          <Image
            src={ceoImage}
            alt={name}
            width={400}
            height={500}
            class="w-full max-h-68 object-cover object-top transition-transform duration-500 hover:scale-105"
          />
        </div>

        {/* Content */}
        <div class=" px-6 py-5 border-t border-white/20">
          <h3
            class="text-white font-dm-mono text-[18px] leading-[150%] font-medium tracking-[-4%] "
          >
            {name}
          </h3>
          <p
            class="text-white mt-2 font-dm-mono text-[14px] leading-[150%] font-normal tracking-[-4%]"
          >
            {designation}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
