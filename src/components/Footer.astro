---
const currentYear = new Date().getFullYear();
---

<footer class="bg-black text-white py-20 border-t border-zinc-900">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-3 gap-16">
    <!-- NAVIGATION -->
    <div>
      <h3 class="text-sm tracking-[2px] text-zinc-500 font-medium mb-6">
        NAVIGATION
      </h3>
      <div class="grid grid-cols-2 gap-x-12 gap-y-4 text-[15px]">
        <a href="#" class="hover:text-orange-400 transition-colors">Home</a>
        <a href="#" class="hover:text-orange-400 transition-colors">Team</a>

        <a href="#" class="hover:text-orange-400 transition-colors">Works</a>
        <a href="#" class="hover:text-orange-400 transition-colors">Blog</a>

        <a href="#" class="hover:text-orange-400 transition-colors">About</a>
        <a href="#" class="hover:text-orange-400 transition-colors">Contact</a>

        <a href="#" class="hover:text-orange-400 transition-colors">Pricing</a>
        <a href="#" class="hover:text-orange-400 transition-colors">Career</a>
      </div>
    </div>

    <!-- SERVICES -->
    <div>
      <h3 class="text-sm tracking-[2px] text-zinc-500 font-medium mb-6">
        SERVICES
      </h3>
      <div class="space-y-4 text-[15px]">
        <a href="#" class="block hover:text-orange-400 transition-colors"
          >Mobile App Design</a
        >
        <a href="#" class="block hover:text-orange-400 transition-colors"
          >SaaS Product Design <span class="text-orange-400">↗</span></a
        >
        <a href="#" class="block hover:text-orange-400 transition-colors"
          >AI Product Design</a
        >
        <a href="#" class="block hover:text-orange-400 transition-colors"
          >Logo and Branding Design</a
        >
        <a href="#" class="block hover:text-orange-400 transition-colors"
          >Website UI/UX Design</a
        >
      </div>
    </div>

    <!-- NEWSLETTER / RIGHT COLUMN -->
    <div class="space-y-8">
      <div>
        <p class="text-zinc-400 text-[15px] leading-relaxed">
          Real client stories, honest design breakdowns,<br />
          and digital strategy that actually works.<br />
          Straight to your inbox, no filler.
        </p>
      </div>

      <!-- Email Input -->
      <div>
        <p class="text-xs tracking-widest text-zinc-500 mb-2">EMAIL</p>
        <div class="relative">
          <input
            type="email"
            placeholder="john@mail.com"
            class="w-full bg-transparent border-b border-zinc-700 pb-3 text-white placeholder-zinc-500 focus:outline-none focus:border-orange-400 transition-colors text-[15px]"
          />
        </div>
      </div>

      <!-- Send Button -->
      <button
        onclick="alert('Subscribed! (Connect your backend)')"
        class="group flex items-center gap-3 bg-orange-500 hover:bg-orange-600 transition-all text-black font-medium px-8 py-4 rounded-xl text-sm tracking-wider"
      >
        SEND
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      </button>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div
    class="max-w-7xl mx-auto px-6 mt-24 pt-8 border-t border-zinc-900 text-xs text-zinc-500 flex flex-col md:flex-row justify-between items-center gap-4"
  >
    <div>© ${currentYear} Panze. All rights reserved.</div>
    <div class="flex gap-6">
      <a href="#" class="hover:text-white transition-colors">Privacy</a>
      <a href="#" class="hover:text-white transition-colors">Legal</a>
    </div>
  </div>
</footer>
