---
import panzelogo from "@/assets/footer/panze.svg";
import { Image } from "astro:assets";
import * as footerData from "@/content/footer-content.md";
import LinkButton from "./ui/LinkButton.astro";
import bdflag from "@/assets/footer/bdflag.svg";
import usflag from "@/assets/footer/usFlag.svg";
import emailIcon from "@/assets/footer/email.svg";
import phone from "@/assets/footer/phone.svg";
import companyDeckIcon from "@/assets/footer/companydeck.svg";
import insta from "@/assets/footer/In.svg";
import fb from "@/assets/footer/FB.svg";
import ln from "@/assets/footer/LN.svg";
import dr from "@/assets/footer/DB.svg";
import be from "@/assets/footer/BE.svg";
import gemini from "@/assets/footer/gemini.svg";
import gpt from "@/assets/footer/gpt.svg";
import pr from "@/assets/footer/preplax.svg";
import clude from "@/assets/footer/clude.svg";
import grok from "@/assets/footer/grok.svg";
import dri from "@/assets/footer/dri.svg";
import clu from "@/assets/footer/clu.svg";
import cta from "@/assets/footer/cta.svg";
const phoneNumber = import.meta.env.PHONE_NUMBER;
const email = import.meta.env.EMAIL_USER;
const facebookUrl = import.meta.env.FACEBOOK_URL;
const instagramUrl = import.meta.env.INSTAGRAM_URL;
const linkedinUrl = import.meta.env.LINKEDIN_URL;
const behanceUrl = import.meta.env.BEHANCE_URL;
const dribbbleUrl = import.meta.env.DRIBBBLE_URL;
const { usLocation, bdLocation, companyDecktext, footerText } =
  footerData.frontmatter;

const prompt = encodeURIComponent(`
Summarize about Panze :

Title: "Panze website"

description:"We are Panze. A specialist digital product design agency built around a single discipline. We design SaaS platforms, web apps, and mobile products. Nothing else, for five years running.

Over the years, we've built SaaS products, platforms, brands, and websites that don't just look good, also performs. Our philosophy is simple: combine strategy, creativity, and technology to solve real business problems and create user experiences that matter." 

Please provide:
- Short summary
- Key takeaways
- Main insights
`);

const aiTools = [
  {
    icon: gemini,
    name: "Gemini",
    url: `https://gemini.google.com/app?q=${prompt}`,
  },
  {
    icon: gpt,
    name: "ChatGPT",
    url: `https://chatgpt.com/?q=${prompt}`,
  },
  {
    icon: pr,
    name: "Perplexity",
    url: `https://www.perplexity.ai/search?q=${prompt}`,
  },
  {
    icon: clude,
    name: "Claude",
    url: `https://claude.ai/new?q=${prompt}`,
  },
  {
    icon: grok,
    name: "Grok",
    url: `https://grok.com?q=${prompt}`,
  },
];
const footerNavigation = [
  { title: "Home", href: "/" },
  { title: "Team", href: "/team" },
  { title: "Works", href: "/works" },
  { title: "Blog", href: "/blog" },
  { title: "About", href: "/about" },
  { title: "Contact", href: "/contact" },
  { title: "Pricing", href: "/pricing" },
  { title: "Career", href: "/career" },
];

const footerServices = [
  {
    title: "Mobile App Design",
    href: "/services/mobile-app-design",
  },
  {
    title: "SaaS Product Design",
    href: "/services/saas-product-design",
  },
  {
    title: "AI Product Design",
    href: "/services/ai-product-design",
  },
  {
    title: "Logo & Branding",
    href: "/services/logo-branding",
  },
  {
    title: "Website UI/UX Design",
    href: "/services/website-ui-ux-design",
  },
];

const pathname = Astro.url.pathname;
const getDateTime = () => {
  const now = new Date();

  return {
    denverTime: now.toLocaleTimeString("en-US", {
      timeZone: "America/Denver",
      hour: "numeric",
      minute: "2-digit",
      hour12: true,
    }),

    bdTime: now.toLocaleTimeString("en-US", {
      timeZone: "Asia/Dhaka",
      hour: "numeric",
      minute: "2-digit",
      hour12: true,
    }),
  };
};

const { denverTime, bdTime } = getDateTime();
---

<!-- pt-10 pb-2 lg:mt-20 -->
<footer id="footer" class="text-[#301C1B] mt-26">
  <div class="max-w-7xl mx-auto px-8">
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-0 border border-black/20"
    >
      <!-- NAVIGATION -->
      <div
        class="footer-navigation lg:col-span-4 lg:border-r border-black/20 px-10 pt-10"
      >
        <h3
          class="font-dm-mono font-medium text-[16px] leading-[150%] uppercase tracking-[-4%] text-[#301C1B] mb-8"
        >
          NAVIGATION
        </h3>

        <div class="grid grid-cols-2 gap-x-10">
          {
            footerNavigation.map((item) => {
              return (
                <a
                  href={item.href}
                  class={`font-dm-mono font-normal text-[14px] leading-[150%] uppercase tracking-[-4%]   group flex items-center justify-between border-b border-dashed border-black/20 pb-2 mb-6 transition-colors text-[#301C1B] hover:text-primary hover:text-[15px] `}
                >
                  <span>{item.title}</span>

                  <span
                    class={`transition-all opacity-0 group-hover:opacity-100 group-hover:translate-x-1 `}
                  >
                    <img src={cta.src} alt="CTA Icon" class="size-4" />
                  </span>
                </a>
              );
            })
          }
        </div>
      </div>

      <!-- SERVICES -->
      <div
        class="footer-services lg:col-span-4 lg:border-r border-black/20 px-10 py-10"
      >
        <h3
          class="font-dm-mono font-medium text-[16px] leading-[150%] uppercase tracking-[-4%] text-[#301C1B] mb-8"
        >
          SERVICES
        </h3>

        <div>
          {
            footerServices.map((item) => {
              const active = pathname === item.href;

              return (
                <a
                  href={item.href}
                  class={`font-dm-mono font-normal text-[14px] leading-[150%] uppercase tracking-[-4%] group flex items-center justify-between border-b border-dashed border-black/20 pb-2 my-6 transition-colors ${
                    active
                      ? "text-primary"
                      : "text-[#301C1B] hover:text-primary"
                  }`}
                >
                  <span>{item.title}</span>

                  <span
                    class={`transition-all opacity-0 group-hover:opacity-100 group-hover:translate-x-1 `}
                  >
                    <img src={cta.src} alt="CTA Icon" class="size-4" />
                  </span>
                </a>
              );
            })
          }
        </div>
      </div>

      <!-- NEWSLETTER -->
      <div class="footer-newslatter lg:col-span-4 py-10 px-10">
        <p
          class="font-dm-mono font-normal text-[16px] leading-[150%] uppercase tracking-[-4%] text-[#301C1B] mb-22.75"
        >
          Real client stories, honest design breakdowns,<br />
          and digital strategy that actually works.<br />
          Straight to your inbox, no filler.
        </p>

        <form id="newsletter-form" class="space-y-6">
          <div>
            <p class="text-xs uppercase tracking-widest border-[#301C1B] mb-2">
              EMAIL
            </p>
            <input
              id="newsletter-email"
              type="email"
              placeholder="john@mail.com"
              required
              class="w-full bg-transparent border-b border-dashed border-[#301C1B] pb-3 text-[#301C1B] placeholder:text-[#301C1B] focus:border-primary outline-none transition-colors text-[15px]"
            />
          </div>

          <button type="submit" class="cursor-pointer">
            <LinkButton text={"SEND"} />
          </button>
        </form>

        <p id="form-message" class="mt-4 text-sm hidden"></p>
      </div>
    </div>

    <!-- Middle Bar -->

    <div class="border border-primary bg-white overflow-hidden">
      <div
        class="relative overflow-hidden
    bg-[radial-gradient(circle,rgba(249,115,22,0.28)_1px,transparent_1px)]
    bg-size-[12px_12px]
    sm:bg-size-[14px_14px]
    lg:bg-size-[16px_16px]"
      >
        <Image
          src={panzelogo}
          alt="Panze Logo"
          width={1600}
          height={500}
          class="footer-logo w-full max-w-none pt-10 px-6 object-cover"
        />
      </div>
    </div>
    <!-- bottom bar -->
    <div class="border border-black/15 border-t-0 bg-[#FAF9F8]">
      <div class="grid lg:grid-cols-[3fr_1fr]">
        <!-- LEFT -->
        <div class="border-r border-black/15">
          <!-- Top -->
          <div
            class="md:flex justify-between px-10 border-b border-/20 pt-10 pb-20"
          >
            <!-- Locations -->
            <div class="space-y-6">
              <div class="footer-location flex items-center gap-3">
                <img src={usflag.src} alt="us" class="w-4.5 h-3" />
                <p
                  class="font-dm-mono font-normal leading-[150%] tracking-[-4%] text[14px]"
                >
                  {usLocation}
                  <span class="mx-2 text-black/30">|</span>
                  <span
                    class="text-primary font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px]"
                    >{denverTime}</span
                  >
                </p>
              </div>

              <div class="footer-location flex items-center gap-3">
                <span
                  ><img src={bdflag.src} alt="bd" class="w-4.5 h-3" />
                </span>
                <p
                  class="font-dm-mono font-normal leading-[150%] tracking-[-4%] text[14px]"
                >
                  {bdLocation}
                  <span class="mx-2 text-black/30">|</span>
                  <span
                    class="text-primary font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px]"
                    >{bdTime}</span
                  >
                </p>
              </div>
            </div>

            <!-- Contact -->
            <div class="pl-10 pt-5 md:pt-0 space-y-6">
              <a
                href={`mailto:${email}`}
                class="footer-location flex items-center gap-2 text-[#301C1B] font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px] hover:text-primary transition-colors"
              >
                <img src={emailIcon.src} alt="email" class="w-3 h-3" />
                <span>{email}</span>
              </a>

              <a
                href={`tel:${phoneNumber.replace(/\s+/g, "")}`}
                class="footer-location flex items-center gap-2 text-[#301C1B] font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px] hover:text-primary transition-colors"
              >
                <img src={phone.src} alt="phone" class="w-4 h-4" />
                <span>{phoneNumber}</span>
              </a>
            </div>
          </div>

          <!-- Bottom -->
          <div class="footer-bottom md:flex justify-between">
            <div class="px-10 py-7">
              <a
                href={""}
                class="mx-auto flex items-center gap-2 text-primary font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px] hover:text-primary transition-colors"
              >
                <img src={companyDeckIcon.src} alt="phone" class="w-4 h-4" />
                <span>{companyDecktext}</span>
              </a>
            </div>

            <div class="px-10 py-2 md:py-7">
              <p
                class="text-[#301C1B] font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px]"
              >
                © {new Date().getFullYear()}, {footerText}
              </p>
            </div>

            <div class="pr-9 flex items-center gap-2 text-2xl">
              {
                [
                  { icon: insta, url: instagramUrl },
                  { icon: fb, url: facebookUrl },
                  { icon: ln, url: linkedinUrl },
                  { icon: be, url: behanceUrl },
                  { icon: dr, url: dribbbleUrl },
                ].map((item) => (
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[#301C1B] hover:text-primary transition-colors"
                  >
                    <img src={item.icon.src} alt="social-icon" />
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <!-- RIGHT -->
        <div class="footer-ai">
          <!-- Top -->
          <div class="px-8 py-8">
            <h2 class="text-[20px] font-semibold mb-6">Ask AI about Panze</h2>

            <div class="grid grid-cols-5 gap-1 mt-5">
              {
                aiTools.map((tool) => (
                  <a
                    href={tool.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex h-11 w-11 items-center justify-center transition-transform hover:scale-105"
                    title={tool.name}
                  >
                    <img
                      src={tool.icon.src}
                      alt={tool.name}
                      class="h-full w-full object-contain"
                    />
                  </a>
                ))
              }
            </div>
          </div>

          <!-- Bottom -->
          <div class="flex justify-center gap-5 py-4">
            <!-- Replace with your badge images -->
            <button class="">
              <img src={clu.src} alt="dirrableAW" class="w-18.75 h-18" />
            </button>
            <button class="">
              <img src={dri.src} alt="clutchAW" class="w-18.75 h-18" />
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#footer",
        start: "top 80%",
        toggleActions: "play none none reverse",
      },
    });

    tl.from(".footer-navigation", {
      x: -80,
      opacity: 0,
      duration: 1,
      ease: "expo.out",
    })

      .from(
        ".footer-services a",
        {
          y: 40,
          opacity: 0,
          stagger: 0.06,
          duration: 0.8,
          ease: "expo.out",
        },
        "-=0.7",
      )

      .from(
        ".footer-newslatter",
        {
          y: 80,
          scale: 0.95,
          opacity: 0,
          duration: 1,
          ease: "expo.out",
        },
        "-=0.6",
      )

      .from(
        ".footer-logo",
        {
          scale: 1.2,
          y: 100,
          opacity: 0,
          duration: 1.5,
          ease: "power4.out",
        },
        "-=0.8",
      )

      .from(
        ".footer-location",
        {
          y: 30,
          opacity: 0,
          stagger: 0.15,
          duration: 0.8,
          ease: "power3.out",
        },
        "-=0.8",
      )

      .from(
        ".footer-ai",
        {
          x: 60,
          opacity: 0,
          duration: 1,
          ease: "expo.out",
        },
        "-=0.6",
      );
    gsap.to(".footer-logo", {
      x: -7,
      duration: 3,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
    });
    gsap.from(".reveal span", {
      yPercent: 100,
      stagger: 0.08,
      duration: 1,
      ease: "power4.out",
    });
    gsap.utils.toArray(".footer-ai a").forEach((item: any) => {
      item.addEventListener("mouseenter", () => {
        gsap.to(item, {
          scale: 1.04,
          y: -3,
          duration: 0.3,
          ease: "back.out(2)",
        });
      });

      item.addEventListener("mouseleave", () => {
        gsap.to(item, {
          scale: 1,
          y: 0,
          duration: 0.3,
        });
      });
    });
</script>
