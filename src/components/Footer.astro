---
import ctaIcon from "@/assets/footer/ctaActionIcon.png";
import panzelogo from "@/assets/footer/panzelogo.png";
import icon from "@/assets/footer/ctaActionIcon.svg";
import { Image } from "astro:assets";
import * as footerData from "@/content/footer-content.md";
const contactUrl = import.meta.env.CONTACT_URL;
const whatsappUrl = import.meta.env.WHATSAPP_URL;
const phoneNumber = import.meta.env.PHONE_NUMBER;
const email = import.meta.env.EMAIL_USER;
const facebookUrl = import.meta.env.FACEBOOK_URL;
const instagramUrl = import.meta.env.INSTAGRAM_URL;
const linkedinUrl = import.meta.env.LINKEDIN_URL;
const behanceUrl = import.meta.env.BEHANCE_URL;
const dribbbleUrl = import.meta.env.DRIBBBLE_URL;
const {
  usFlag,
  bdFlag,
  usLocation,
  bdLocation,
  phoneIcon,
  emailIcon,
  companyDeckIcon,
  companyDecktext,
  footerText,
  instagramIcon,
  facebookIcon,
  linkdinIcon,
  dirrableIcon,
  behanceIcon,
  askAiText,
  geminiIcon,
  openaiIcon,
  perplexityIcon,
  cludeIcon,
  grokIcon,
  dirrableAW,
  clutchAW,
} = footerData.frontmatter;

const footerNavigation = [
  { title: "Home", href: "/" },
  { title: "Team", href: "/team" },
  { title: "Works", href: "/works" },
  { title: "Blog", href: "/blog" },
  { title: "About", href: "/about" },
  { title: "Contact", href: "/contact" },
  { title: "Pricing", href: "/pricing" },
  { title: "Career", href: "/career" },
];

const footerServices = [
  {
    title: "Mobile App Design",
    href: "/services/mobile-app-design",
  },
  {
    title: "SaaS Product Design",
    href: "/services/saas-product-design",
  },
  {
    title: "AI Product Design",
    href: "/services/ai-product-design",
  },
  {
    title: "Logo & Branding",
    href: "/services/logo-branding",
  },
  {
    title: "Website UI/UX Design",
    href: "/services/website-ui-ux-design",
  },
];

const pathname = Astro.url.pathname;
const getDateTime = () => {
  const now = new Date();

  return {
    denverTime: now.toLocaleTimeString("en-US", {
      timeZone: "America/Denver",
      hour: "numeric",
      minute: "2-digit",
      hour12: true,
    }),

    bdTime: now.toLocaleTimeString("en-US", {
      timeZone: "Asia/Dhaka",
      hour: "numeric",
      minute: "2-digit",
      hour12: true,
    }),
  };
};

const { denverTime, bdTime } = getDateTime();
---

<footer class="text-[#301C1B] pt-10 pb-2 lg:mt-20  ">
  <div class="max-w-7xl mx-auto px-6 lg:px-10">
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-0 border border-black/20"
    >
      <!-- NAVIGATION -->
      <div
        class="lg:col-span-4 lg:border-r border-black/20 px-6 lg:px-10 py-8 lg:py-10"
      >
        <h3
          class="font-dm-mono font-medium text-[16px] leading-[150%] uppercase tracking-[-4%] text-[#301C1B] mb-8"
        >
          NAVIGATION
        </h3>

        <div class="grid grid-cols-2 gap-x-8">
          {
            footerNavigation.map((item) => {
              const active = pathname === item.href;

              return (
                <a
                  href={item.href}
                  class={`font-dm-mono font-normal text-[14px] leading-[150%] uppercase tracking-[-4%]   group flex items-center justify-between border-b border-dashed border-black/20 py-3 transition-colors ${
                    active
                      ? "text-primary border-primary"
                      : "text-[#301C1B] hover:text-primary border-black/20"
                  }`}
                >
                  <span>{item.title}</span>

                  <span
                    class={`transition-all ${
                      active
                        ? "opacity-100 translate-x-0"
                        : "opacity-0 group-hover:opacity-100 group-hover:translate-x-1"
                    }`}
                  >
                    <Image src={ctaIcon} alt="CTA Icon" width={8} height={8} />
                  </span>
                </a>
              );
            })
          }
        </div>
      </div>

      <!-- SERVICES -->
      <div
        class="lg:col-span-4 lg:border-r border-black/20 px-6 lg:px-10 py-8 lg:py-10"
      >
        <h3
          class="font-dm-mono font-medium text-[16px] leading-[150%] uppercase tracking-[-4%] text-[#301C1B] mb-8"
        >
          SERVICES
        </h3>

        <div>
          {
            footerServices.map((item) => {
              const active = pathname === item.href;

              return (
                <a
                  href={item.href}
                  class={`font-dm-mono font-normal text-[14px] leading-[150%] uppercase tracking-[-4%] group flex items-center justify-between border-b border-dashed border-black/20 py-4 transition-colors ${
                    active
                      ? "text-primary"
                      : "text-[#301C1B] hover:text-primary"
                  }`}
                >
                  <span>{item.title}</span>

                  <span
                    class={`transition-all ${
                      active
                        ? "opacity-100 translate-x-0"
                        : "opacity-0 group-hover:opacity-100 group-hover:translate-x-1"
                    }`}
                  >
                    <Image src={ctaIcon} alt="CTA Icon" width={8} height={8} />
                  </span>
                </a>
              );
            })
          }
        </div>
      </div>

      <!-- NEWSLETTER -->
      <div class="lg:col-span-4 px-6 lg:px-10 py-8 lg:py-10">
        <p
          class="font-dm-mono font-normal text-[16px] leading-[150%] uppercase tracking-[-4%] text-[#301C1B] mb-8"
        >
          Real client stories, honest design breakdowns,<br />
          and digital strategy that actually works.<br />
          Straight to your inbox, no filler.
        </p>

        <form id="newsletter-form" class="space-y-6">
          <div>
            <p class="text-xs uppercase tracking-widest border-[#301C1B] mb-2">
              EMAIL
            </p>
            <input
              id="newsletter-email"
              type="email"
              placeholder="john@mail.com"
              required
              class="w-full bg-transparent border-b border-dashed border-[#301C1B] pb-3 text-[#301C1B] placeholder:text-[#301C1B] focus:border-primary outline-none transition-colors text-[15px]"
            />
          </div>

          <button
            type="submit"
            class="font-commissioner font-normal text-[14px] leading-[150%] tracking-[-4%] bg-primary hover:bg-orange-600 transition-colors text-white px-8 py-2 rounded-none flex items-center gap-3 group w-fit"
          >
            SEND
            <span
              class="group-hover:translate-x-1 transition-transform text-lg"
            >
              <Image src={icon} alt="CTA Icon" width={8} height={8} /></span
            >
          </button>
        </form>

        <p id="form-message" class="mt-4 text-sm hidden"></p>
      </div>
    </div>

    <!-- Middle Bar -->

    <div class="border border-primary bg-white overflow-hidden">
      <div
        class="relative overflow-hidden
    bg-[radial-gradient(circle,rgba(249,115,22,0.28)_1px,transparent_1px)]
    bg-size-[12px_12px]
    sm:bg-size-[14px_14px]
    lg:bg-size-[16px_16px]"
      >
        <Image
          src={panzelogo}
          alt="Panze Logo"
          width={1600}
          height={500}
          class="w-full max-w-none px-6 mt-3 md:mt-5 object-cover"
        />
      </div>
    </div>
    <!-- bottom bar -->
    <div class="border border-black/15 border-t-0 bg-[#FAF9F8]">
      <div class="grid lg:grid-cols-[3fr_1fr]">
        <!-- LEFT -->
        <div class="border-r border-black/15">
          <!-- Top -->
          <div class=" px-2 md:px-0 md:flex justify-around border-b border-/20 py-14">
            <!-- Locations -->
            <div class="space-y-6">
              <div class="flex items-center gap-3">
                <img src={usFlag} alt="us" />
                <p
                  class=" text-[13px] font-dm-mono font-normal leading-[150%] tracking-[-4%] md:text[14px]"
                >
                  {usLocation}
                  <span class="mx-2 text-black/30">|</span>
                  <span
                    class="text-primary font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px]"
                    >{denverTime}</span
                  >
                </p>
              </div>

              <div class="flex items-center gap-3">
                <span><img src={bdFlag} alt="" /> </span>
                <p
                  class=" text-primary font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[13px] md:text-[14px]"
                >
                  {bdLocation}
                  <span class="mx-2 text-black/30">|</span>
                  <span
                    class="text-primary font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px]"
                    >{bdTime}</span
                  >
                </p>
              </div>
            </div>

            <!-- Contact -->
            <div class="md:pl-10 pt-5 md:pt-0 space-y-6">
              <a
                href={`mailto:${email}`}
                class="flex items-center gap-2 text-[#301C1B] font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px] hover:text-primary transition-colors"
              >
                <img src={emailIcon} alt="email" class="w-3 h-3" />
                <span>{email}</span>
              </a>

              <a
                href={`tel:${phoneNumber.replace(/\s+/g, "")}`}
                class="flex items-center gap-2 text-[#301C1B] font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px] hover:text-primary transition-colors"
              >
                <img src={phoneIcon} alt="phone" class="w-3 h-3" />
                <span>{phoneNumber}</span>
              </a>
            </div>
          </div>

          <!-- Bottom -->
          <div class="md:flex justify-between">
            <div class="px-10 py-4 md:py-7">
              <a
                href={""}
                class="mx-auto flex items-center gap-2 text-primary font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px] hover:text-primary transition-colors"
              >
                <img src={companyDeckIcon} alt="phone" class="w-3 h-3" />
                <span>{companyDecktext}</span>
              </a>
            </div>

            <div class="px-10 py-2 md:py-7">
              <p
                class="text-[#301C1B] font-dm-mono font-normal leading-[150%] tracking-[-4%] text-[14px]"
              >
                © {new Date().getFullYear()}, {footerText}
              </p>
            </div>

            <div class="px-10 md:px-0 md:pr-5 py-7 flex items-center gap-6 text-2xl">
              {
                [
                  { icon: instagramIcon, url: instagramUrl },
                  { icon: facebookIcon, url: facebookUrl },
                  { icon: linkdinIcon, url: linkedinUrl },
                  { icon: behanceIcon, url: behanceUrl },
                  { icon: dirrableIcon, url: dribbbleUrl },
                ].map((item) => (
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[#301C1B] hover:text-primary transition-colors"
                  >
                    <img src={item.icon} alt="social-icon"/>
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <!-- RIGHT -->
        <div>
          <!-- Top -->
          <div class="px-8 py-8">
            <h2 class="text-[20px] font-semibold mb-6">Ask AI about Panze</h2>

            <div class="grid grid-cols-5 gap-2">
              <button class="w-11 h-11">
                <img src={geminiIcon} alt="gemini" />
              </button>
              <button class="w-11 h-11">
                <img src={openaiIcon} alt="openai" />
              </button>
              <button class="w-11 h-11">
                <img src={perplexityIcon} alt="perplexity" />
              </button>
              <button class="w-11 h-11">
                <img src={cludeIcon} alt="clude" />
              </button>
              <button class="w-11 h-11">
                <img src={grokIcon} alt="grok" />
              </button>
            </div>
          </div>

          <!-- Bottom -->
          <div class="flex justify-center gap-5 py-4">
            <!-- Replace with your badge images -->
            <button class="">
              <img src={dirrableAW} alt="dirrableAW" />
            </button>
            <button class="">
              <img src={clutchAW} alt="clutchAW" />
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
