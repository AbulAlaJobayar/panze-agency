---
import { Icon } from "../ui/icon";

const benefits = [
  {
    icon: "gift",
    title: "Two Festival Bonuses",
    description:
      "Double the joy, double the rewards. Get two festival bonuses every year, each worth 50% of your gross salary.",
  },
  {
    icon: "badge-check",
    title: "Mentorship & Personal Growth",
    description:
      "We're not bosses, we're mentors. Get hands-on guidance that helps you sharpen your skills and reach your full potential.",
  },
  {
    icon: "wifi",
    title: "Device & Internet Allowance",
    description:
      "Work without worry. We provide a monthly allowance to cover your device costs and internet connection.",
  },
  {
    icon: "heart",
    title: "Health & Wellness Allowance",
    description:
      "Your health comes first. Receive support for medical checkups, treatments, and wellness needs.",
  },
  {
    icon: "calendar",
    title: "Generous Leave Benefits",
    description:
      "Enjoy ample paid leave throughout the year so you can recharge without losing income.",
  },
  {
    icon: "bank",
    title: "Emergency Loan Facilities",
    description:
      "Interest-free emergency loans are available whenever you need financial support.",
  },
  {
    icon: "trophy",
    title: "Performance Bonuses",
    description:
      "Hit your goals and earn extra bonuses on top of your regular salary.",
  },
  {
    icon: "graduation-cap",
    title: "Learning & Development",
    description:
      "We sponsor certifications, courses, and learning resources to help you grow.",
  },
];
---

<section class="">
  <div class="mx-auto">
    <!-- Header -->
    <div
      class="grid
             px-8 py-12
             lg:grid-cols-[180px_1fr_420px]
             lg:px-10"
    >
      <div>
        <span
          class="flex items-center gap-2 font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%] text-primary"
        >
          <Icon name="star" class="size-4" />
          Facilities
        </span>
      </div>

      <h2
        class="mt-6 lg:mt-0
               max-w-100
               font-commissioner
               font-semibold
               text-[24px]
               leading-[110%] tracking-[-4%] uppercase"
      >
        A Workplace That Supports How You Live
      </h2>

      <p
        class="mt-6 lg:mt-0
               justify-self-end
              font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%]"
      >
        Panze brings together UX research, information architecture, conversion
        strategy, and visual craft in one integrated website design process.
      </p>
    </div>

    <!-- Benefits -->
    <div class="grid lg:grid-cols-2">
      {
        benefits.map((item, index) => (
          <div
            class:list={[
              "border-b border-black/20",
              index % 2 === 0 && "lg:border-r border-black/20",
            ]}
          >
            <div
              class="grid gap-2
                     px-8 py-10
                     lg:grid-cols-[170px_1fr]
                    "
            >
              <div>
                <Icon name={item.icon} class="mb-2 size-5 text-primary" />

                <h3 class="font-dm-mono font-medium text-[16px] leading-[150%] tracking-[-4%] text-primary">
                  {item.title}
                </h3>
              </div>

              <p class="font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%]">
                {item.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
