---
import sectionIcon from "@/assets/sectionIcon/faq.svg";
import Faqs from "./faqs.astro";
const { industryExpert } = Astro.props;
const { title, subtitle, description, faqs } = industryExpert;
---

<section class="overflow-hidden bg-[#1E1212] py-26 mt-26">
  <div class="flex flex-col lg:flex-row border-y border-white/20">
    <!-- Content -->
    <div
      class="w-full lg:w-100 lg:shrink-0
           border-b border-white/10
           lg:border-b-0 lg:border-r
           px-8 
           py-12 md:py-16 lg:py-20"
    >
      <div class="flex items-center gap-2">
        <img src={sectionIcon.src} alt={title} class="size-3 md:size-auto" />

        <h6
          class="font-dm-mono
               text-xs sm:text-sm
               font-normal
               leading-[150%]
               tracking-[-0.04em]
               text-primary"
        >
          {title}
        </h6>
      </div>

      <h2
        class="mt-8
             font-commissioner
             text-xl sm:text-2xl md:text-[28px]
             font-semibold
             uppercase
             leading-[110%]
             tracking-[-0.04em]
             text-white"
      >
        {subtitle}
      </h2>

      <p
        class="mt-8 md:mt-10
             max-w-md
             font-dm-mono
             text-sm
             leading-[150%]
             tracking-[-0.04em]
             text-white/80"
      >
        {description}
      </p>
    </div>

    <!-- FAQ -->
    <div
      class="flex-1
           border-white/10
           lg:border-l
           
           py-8 md:py-10 lg:py-12"
    >
      <Faqs faqs={faqs} />
    </div>
  </div>
</section>
