---
import * as herodata from "@/content/services/website/website-hero-content.md";

import ctaIcon from "@/assets/home/heroimage/ctaActionIcon.svg";
import ctaIcon2 from "@/assets/services/icon.png";
import NavigationMenuLink from "@/components/ui/navigation-menu/navigation-menu-link.astro";

// Access frontmatter data
const { subTitle, description, buttonText, buttonLink, image } =
  herodata.frontmatter;
---

<section class="border-b overflow-hidden">
  <div class="flex flex-col lg:flex-row items-stretch">
    <!-- Left Side - Fixed width with white background -->
    <div
      class="w-full lg:w-100 shrink-0 border-b lg:border-b-0 lg:border-r px-6 sm:px-8 md:px-10 py-6 md:py-8 lg:py-10 bg-white"
    >
      <h3
        class="font-commissioner font-semibold text-[28px] uppercase leading-[110%] tracking-[-4%] text-primary py-10"
      >
        {subTitle}
      </h3>
      <p
        class="font-dm-mono mt-5 font-normal text-[14px] leading-[150%] tracking-[-4%]"
      >
        {description}
      </p>
      <!-- button -->
      <div class="flex gap-8 items-center">
        <NavigationMenuLink
          href={buttonLink}
          class=" h-11.25 py-3 px-2.5 bg-primary my-10 mt-5 lg:mt-26 hover:bg-primary cursor-pointer flex items-center justify-center gap-2 rounded-none"
        >
          <span
            class="font-commissioner font-normal text-[14px] leading-[150%] tracking-[-4%] text-white"
          >
            {buttonText}
          </span>
          <img src={ctaIcon.src} alt="icon" class="h-2 w-2" />
        </NavigationMenuLink>
      </div>
    </div>

    <!-- Right Side - Background image ONLY on right side -->
    <div
      class="  p-4  "
    >
      <img src={image} alt="website" />
    </div>
  </div>
</section>
