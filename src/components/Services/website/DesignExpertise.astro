---
import * as designExpertise from "@/content/services/website/design-expertise-content.md";

import { Image } from "astro:assets";
const { sectionIcon, title, subtitle, description, steps } =
  designExpertise.frontmatter;

const services = [
  {
    title: "Marketing and SaaS Website Design",
    description:
      "Value communicated clearly, visitors converted confidently. Marketing and SaaS websites designed to turn curiosity into qualified leads and signups.",
  },
  {
    title: "Landing Page and Conversion Design",
    description:
      "Every element earns its place. Landing pages built around conversion goals so visitors always have a clear and compelling next step.",
  },
  {
    title: "Information Architecture and Sitemap Design",
    description:
      "Content made findable, navigation made logical, and the path to conversion made completely effortless through thoughtful website structure design.",
  },
  {
    title: "Website Component and Design System Creation",
    description:
      "Component libraries and design systems built to keep your site visually consistent and future updates significantly faster to implement.",
  },
  {
    title: "Developer Handoff and Specification Documentation",
    description:
      "Annotated files, spacing specs, and usage guidelines delivered so your website gets built exactly as designed without interpretation or guesswork.",
  },
  {
    title: "Website UX Research and Audit",
    description:
      "Drop-off points identified, conversion gaps surfaced, and missed opportunities uncovered through structured UX research and website audit processes.",
  },
  {
    title: "Responsive UI Design for Web",
    description:
      "Consistent, high-quality visual experience delivered across desktop, tablet, and mobile so no visitor ever gets a degraded version.",
  },
];
---

<div class="my-20">
  <div class="flex flex-col lg:flex-row border-b border-white/20">
    <!-- Left: Icon + Title -->
    <div
      class="w-full lg:w-[20%] border-b lg:border-b-0 lg:border-r border-white/20 px-6 sm:px-8 md:px-10 py-10 md:py-12 lg:py-16"
    >
      <div class="flex items-center gap-3">
        <Image
          src={sectionIcon}
          alt="Latest icon"
          width={16}
          height={14}
          class="w-5 h-5 md:w-auto md:h-auto -mt-2"
        />
        <h6
          class="font-dm-mono font-normal text-[12px] sm:text-[14px] leading-[150%] tracking-[-4%] text-primary"
        >
          {title}
        </h6>
      </div>
    </div>

    <!-- Middle: SubTitle -->
    <div
      class="w-full lg:w-[40%] border-b lg:border-b-0 lg:border-r border-white/20 px-6 sm:px-8 md:px-10 md:py-12 lg:py-16"
    >
      <p
        class="font-commissioner font-semibold text-[24px] sm:text-[22px] md:text-[24px] leading-[110%] tracking-[-4%] uppercase text-[#301C1B]"
      >
        {subtitle}
      </p>
    </div>

    <!-- Right: Description -->
    <div
      class="w-full lg:w-[40%] px-6 sm:px-8 md:px-10 py-10 md:py-12 lg:py-16"
    >
      <p
        class="text-[#301C1B] font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%]"
      >
        {description}
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2">
    {
      steps.map((service: any, index: any) => (
        <article
          class:list={[
            "grid md:grid-cols-[220px_1fr] gap-8 p-8 lg:p-10 min-h-42.5",
            "border-b border-black/10",
            index % 2 === 0 && "border-r border-black/20",
          ]}
        >
          <h3 class=" font-dm-mono font-medium text-[16px] leading-[150%] tracking-[-4%] text-primary">
            {service.title}
          </h3>
          <p>{service.description}</p>
        </article>
      ))
    }
  </div>
</div>
