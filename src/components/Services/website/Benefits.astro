---
const { benifits } = Astro.props;
import sectionicon from "@/assets/sectionIcon/benifitsicon.svg";

const { title, subTitle, description, steps } = benifits;
---

<section id="benifitsSection" class="border-y overflow-hidden">
  <div class=" flex flex-col lg:flex-row items-center">
    <!-- Left Side - Fixed width with white background -->
    <div
      class="py-10 lg:py-0 benefits-content w-full lg:w-100 shrink-0 border-b lg:border-b-0 px-8"
    >
      <div class="benefits-title flex items-center gap-2 mb-9.5">
        <img
          src={sectionicon.src}
          alt="benifit section"
          class="w-3 h-3 md:w-auto md:h-auto"
        />
        <h6
          class="font-dm-mono font-normal [14px] leading-[150%] tracking-[-4%] text-primary"
        >
          {title}
        </h6>
      </div>
      <h3
        class="benefits-subTitle mb-14 font-commissioner font-semibold text-[28px] uppercase leading-[110%] tracking-[-4%] text-[#301C1B]"
      >
        {subTitle}
      </h3>
      <p
        class="benefits-description font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%]"
      >
        {description}
      </p>
    </div>

    <!-- Right Side - Background image ONLY on right side -->
    <div class="border-l">
      <div class="grid grid-cols-1 sm:grid-cols-2 border border-white/20">
        {
          steps.map((step: any, index: any) => (
            <div
              class="benefit-card border-r border-b  p-8  min-h-47.5
                lg:even:border-r-0
               nth-last-[-n+2]:border-b-0"
            >
              <h3 class="benefit-number font-dm-mono font-medium text-[16px] leading-[150%] tracking-[-4%] text-[#301C1B] mb-6">
                {index + 1}. {step.title}
              </h3>

              <p class="font-dm-mono text-[14px] leading-[150%] tracking-[-4%] text-[#5A4F4E] max-w-[320px]">
                {step.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const tl = gsap.timeline({
    scrollTrigger: {
      trigger: "#benifitsSection",
      start: "top 75%",
      toggleActions: "play none none reverse",
    },
  });

  // Left content reveal
  tl.from(".benefits-content", {
    x: -80,
    opacity: 0,
    filter: "blur(15px)",
    duration: 1.2,
    ease: "expo.out",
  });

  // Title reveal
  tl.from(
    ".benefits-title",
    {
      yPercent: 120,
      duration: 1,
      ease: "power4.out",
    },
    "-=0.7",
  );

  // Description reveal
  tl.from(
    ".benefits-subTitle",
    {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: "power3.out",
    },
    "-=0.6",
  );
  tl.from(
    ".benefits-description",
    {
      y: 40,
      opacity: 0,
      duration: 0.8,
      ease: "power3.out",
    },
    "-=0.5",
  );

  // Cards stagger
  tl.from(
    ".benefit-card",
    {
      y: 80,
      opacity: 0,
      stagger: {
        amount: 0.5,
        grid: "auto",
        from: "start",
      },
      duration: 1,
      ease: "power4.out",
    },
    "-=0.5",
  );

  // Numbers reveal
  tl.from(
    ".benefit-number",
    {
      y: 20,
      opacity: 0,
      stagger: 0.08,
      duration: 0.5,
    },
    "-=0.8",
  );
</script>
