---
import { Image } from "astro:assets";
const { data } = Astro.props;


// Access frontmatter data
const { title, subTitle, description, benefitsIcon, steps } = data.frontmatter;
---

<section class="border-y overflow-hidden mb-20">
  <div class="flex flex-col lg:flex-row items-center">
    <!-- Left Side - Fixed width with white background -->
    <div
      class="w-full lg:w-100 shrink-0 border-b lg:border-b-0 px-6 sm:px-8 md:px-10 py-6 md:py-8 lg:py-10 bg-white"
    >
      <div class="flex items-center gap-3 mb-6">
        <Image
          src={benefitsIcon}
          alt="benifit section"
          width={16}
          height={14}
          class="w-4h-4 md:w-auto md:h-auto"
        />
        <h6
          class="font-dm-mono font-normal text-[12px] sm:text-[14px] leading-[150%] tracking-[-4%] text-primary"
        >
          {title}
        </h6>
      </div>
      <h3
        class="font-commissioner font-semibold text-[28px] uppercase leading-[110%] tracking-[-4%] text-[#301C1B] py-10"
      >
        {subTitle}
      </h3>
      <p
        class="font-dm-mono mt-5 font-normal text-[14px] leading-[150%] tracking-[-4%]"
      >
        {description}
      </p>
      <!-- button -->
    </div>

    <!-- Right Side - Background image ONLY on right side -->
    <div class="border-l">
      <div class="grid grid-cols-1 md:grid-cols-2 border border-white/20">
        {
          steps.map((step: any, index: any) => (
            <div
              class="border-r border-b  p-8 md:p-10 min-h-47.5
               even:border-r-0
               nth-last-[-n+2]:border-b-0"
            >
              <h3 class="font-dm-mono font-medium text-[16px] leading-[150%] tracking-[-4%] text-[#301C1B] mb-6">
                {index + 1}. {step.title}
              </h3>

              <p class="font-dm-mono text-[14px] leading-[150%] tracking-[-4%] text-[#5A4F4E] max-w-[320px]">
                {step.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
