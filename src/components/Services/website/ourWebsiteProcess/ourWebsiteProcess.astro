---
import OurWebsiteProcess from "@/components/Services/website/ourWebsiteProcess/OurWebsiteProcess";
import icon from "@/assets/sectionIcon/networkIcon.svg";
const { ourProcess } = Astro.props;
const { title, subtitle, description, steps } = ourProcess;
---

<div id="ourWebsiteProcessServices" class="my-26">
  <div class="flex flex-col lg:flex-row border-b border-white/20 px-8 pt-26">
    <!-- Left: Icon + Title -->
    <div
      class="w-full lg:w-[20%] border-b lg:border-b-0 lg:border-r border-white/20"
    >
      <div
        class="mb-8 lg:mb-0 ourWebsiteProcessServicesTitle flex items-center gap-3"
      >
        <img
          src={icon.src}
          alt="Latest icon"
          class="w-3 h-3 md:w-auto md:h-auto"
        />
        <h6
          class="font-dm-mono font-normal text-[12px] sm:text-[14px] leading-[150%] tracking-[-4%] text-primary"
        >
          {title}
        </h6>
      </div>
    </div>

    <!-- Middle: SubTitle -->
    <div
      class="mb-8 lg:mb-0 w-full lg:w-[35%] border-b lg:border-b-0 lg:border-r border-white/20"
    >
      <p
        class="ourWebsiteProcessServicesSubtitle font-commissioner font-semibold text-[24px] sm:text-[22px] md:text-[24px] leading-[110%] tracking-[-4%] uppercase text-[#301C1B]"
      >
        {subtitle}
      </p>
    </div>

    <!-- Right: Description -->
    <div
      class="ourWebsiteProcessServicesDescription mb-16 w-full lg:w-[42%] ml-auto"
    >
      <p
        class="text-[#301C1B] font-dm-mono font-normal text-[14px] leading-[150%] tracking-[-4%]"
      >
        {description}
      </p>
    </div>
  </div>
  <OurWebsiteProcess client:load data={steps} />
</div>
<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const initAnimation = () => {
    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: "#ourWebsiteProcessServices",
        start: "top 75%",
        once: true,
      },
    });

    tl.from(".ourWebsiteProcessServicesTitle", {
      x: -40,
      opacity: 0,
      duration: 0.8,
      ease: "power3.out",
    })
      .from(
        ".ourWebsiteProcessServicesSubtitle",
        {
          y: 40,
          opacity: 0,
          duration: 0.9,
          ease: "power3.out",
        },
        "-=0.5",
      )
      .from(
        ".ourWebsiteProcessServicesDescription",
        {
          x: 40,
          opacity: 0,
          duration: 0.8,
          ease: "power3.out",
        },
        "-=0.5",
      );
  };

  initAnimation();
</script>
