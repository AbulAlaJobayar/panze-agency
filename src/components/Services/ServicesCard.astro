---
import { Image } from "astro:assets";
import { Button } from "../ui/button";
import { Icon } from "../ui/icon";
import background from "@/assets/services/bgCard.png";

const { data } = Astro.props;
---

<div class="border-b border-[#E7E2DF]">
  <div class="grid lg:grid-cols-2">
    {/* Left */}
    <div
      style={`background-image:url(${background.src})`}
      class="flex items-center justify-center border-b border-[#E7E2DF] lg:border-b-0 lg:border-r bg-cover bg-center bg-no-repeat px-8 py-10 lg:px-12 lg:py-14"
    >
      <Image
        src={data.image}
        alt={data.title}
        width={900}
        height={700}
        class="w-full max-w-115 object-contain"
      />
    </div>

    {/* Right */}
    <div class="flex flex-col justify-center px-8 py-10 lg:px-12 lg:py-14">
      <div class="max-w-140">
        <h2
          class="font-commissioner text-[20px] font-semibold uppercase leading-[110%] tracking-[-4%] text-[#301C1B]"
        >
          {data.title}
        </h2>

        <p
          class="mt-3 font-dm-mono text-[14px] leading-[150%] tracking-[-4%] text-[#5A4A48]"
        >
          {data.servicesSubTitle}
        </p>

        <p
          class="mt-2 font-dm-mono text-[14px] leading-[180%] tracking-[-0.04em] text-[#5A4A48]"
        >
          {data.servicesDescription}
        </p>

        <h3
          class="mt-4 font-commissioner text-[18px] font-semibold leading-[120%] text-[#301C1B]"
        >
          {data.whatWeDeliver}
        </h3>

        <p
          class="mt-2 font-dm-mono text-[14px] leading-[150%] tracking-[-4%] text-[#5A4A48]"
        >
          {data.whatWeDeliverDetails}
        </p>

        <Button class="mt-10 rounded-none px-7 py-6">
          <span
            class="font-commissioner font-normal text-[14px] leading-[150%] tracking-[-4%]"
            >Learn more</span
          >
          <Icon name="arrow-up-right" class="ml-2 h-4 w-4" />
        </Button>
      </div>
    </div>
  </div>
</div>
