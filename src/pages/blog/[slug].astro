---
import Footer from "@/components/Footer.astro";
import "../../styles/global.css";
import Layout from "@/layouts/Layout.astro";
import ContactSection from "@/components/contactSection/ContactSection.astro";
import ContentLayout from "@/components/blog/blogDetails/contentLayout.astro";
import RecentBlog from "@/components/blog/blogDetails/recentBlog.astro";

const blogs = Object.values(
  import.meta.glob("../../content/blogs/blog/*.{md,mdx}", { eager: true }),
).sort((a: any, b: any) => a.frontmatter.order - b.frontmatter.order);

export async function getStaticPaths() {
  return blogs.map(({ frontmatter }: any) => ({
    params: {
      slug: frontmatter.slug,
    },
  }));
}

const { slug } = Astro.params;

const blog = blogs.find(({ frontmatter }: any) => frontmatter.slug === slug);



const { frontmatter, Content } = blog as any;

---

<Layout title="BLOG | PANZE">
  <ContentLayout frontmatter={frontmatter} Content={Content} />
  <RecentBlog/>
  <ContactSection />
  <Footer />
</Layout>
