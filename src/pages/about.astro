---
import AboutHeroSection from "@/components/about/aboutHeroSection.astro";
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
import ContactSection from "@/components/contactSection/ContactSection.astro";
import Footer from "@/components/Footer.astro";
import Number from "@/components/Home/Number.astro";
import * as number from "@/content/about/about-number-content.md";
import OurProcess from "@/components/OurProcess/OurProcess.astro";
import * as ourProcess from "@/content/about/how-we-works-content.md";
import OurBeliefs from "@/components/about/ourBeliefs.astro";
import StatsSection from "@/components/about/statsSection.astro";
import Clients from "@/components/about/clients.astro";
import Testimonial from "@/components/about/testimonial.astro";
---

<Layout title="ABOUT | PANZE">
  <AboutHeroSection />
  <Number data={number} />
  <OurBeliefs/>
  <StatsSection/>
  <OurProcess ourProcess={ourProcess} />
  <Clients/>
  <Testimonial/>
  <ContactSection />
  <Footer />
</Layout>
