---
import Footer from "@/components/Footer.astro";
import Layout from "@/layouts/Layout.astro";
import ContactSection from "@/components/contactSection/ContactSection.astro";
import HeroServicesSection from "@/components/Services/website/HeroServicesSection.astro";
import OurWebsiteProcess from "@/components/Services/website/ourWebsiteProcess/ourWebsiteProcess.astro";

const services = Object.values(
  import.meta.glob("../../content/whatwedo/*.md", { eager: true }),
).sort((a: any, b: any) => a.frontmatter.order - b.frontmatter.order);

export async function getStaticPaths() {
  return services.map(({ frontmatter }: any) => ({
    params: {
      slug: frontmatter.slug,
    },
  }));
}

const { slug } = Astro.params;
const service = services.find(
  ({ frontmatter }: any) => frontmatter.slug === slug,
);
const { frontmatter } = service as any;
console.log(frontmatter, "👍👍👍");
---

<Layout title={frontmatter.siteTitle}>
  <HeroServicesSection hero={frontmatter.hero} />
  <OurWebsiteProcess ourProcess={frontmatter.ourProcess} />
  <ContactSection />
  <Footer />
</Layout>
