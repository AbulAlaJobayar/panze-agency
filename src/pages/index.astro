---
import HeroSection from "@/components/Home/HeroSection.astro";
import Layout from "../layouts/Layout.astro";
import * as hero from "../content/home/hero-content.md";
import Blackbox from "@/components/Home/blackbox.astro";
import Number from "@/components/Home/Number.astro";
import AboutSection from "@/components/Home/AboutSection.astro";
import BrandSection from "@/components/BrandSection.astro";
import LatestWork from "@/components/Home/LatestWork.astro";
import OurProcess from "@/components/OurProcess/OurProcess.astro";
import WhatWeDo from "@/components/WhatWeDo/WhatWeDo.astro";
import Industry from "@/components/Home/Industry.astro";
import FrequentlyAskedFAQ from "@/components/FrequentlyAsked/FrequentlyAskedFAQ.astro";
import TeamSection from "@/components/TeamSection.astro";
import BlogSection from "@/components/Home/BlogSection.astro";
import ContactSection from "@/components/contactSection/ContactSection.astro";
import Footer from "@/components/Footer.astro";
import Review from "@/components/Home/review/Review.astro";
import * as ourProcess from "@/content/ourprocess-content.md";
import * as data from "@/content/home/number-content.md";
import * as askedQuestion from "@/content/frequentlyAsked-content.md";
import * as sectiondata from "@/content/whatwedo/mainContent/whatwedo-content.md";
const services = Object.values(
  import.meta.glob("@/content/whatwedo/*.md", { eager: true }),
).sort((a: any, b: any) => a.frontmatter.order - b.frontmatter.order);
---

<Layout title="HOME | PANZE">
  <HeroSection hero={hero} />
  <Blackbox />
  <Number data={data} />
  <AboutSection />
  <BrandSection />
  <LatestWork />
  <OurProcess ourProcess={ourProcess} />
  <WhatWeDo sectiondata={sectiondata} services={services} />
  <Industry />
  <Review />
  <FrequentlyAskedFAQ askedQuestion={askedQuestion} />
  <TeamSection />
  <BlogSection />
  <ContactSection />
  <Footer />
</Layout>
